PORT=3000
HOST=127.0.0.1
AI_SHIELD_ALLOWED_ORIGINS=http://127.0.0.1:3000,http://localhost:3000
AI_SHIELD_MASTER_KEY=replace-with-a-long-random-value
AI_SHIELD_ADMIN_USERNAME=admin
AI_SHIELD_ADMIN_PASSWORD_HASH=replace-with-output-from-npm-run-admin-hash
AI_SHIELD_ADMIN_OTP_SECRET=replace-with-output-from-npm-run-admin-otp-secret
AI_SHIELD_ADMIN_IP_WHITELIST=127.0.0.1,::1
AI_SHIELD_ADMIN_FAILED_LOGIN_LIMIT=3
AI_SHIELD_ADMIN_SESSION_TTL_MIN=30
AI_SHIELD_ADMIN_IDLE_TIMEOUT_MIN=15
AI_SHIELD_AUTH_DEBUG=false
AI_SHIELD_LOG_FILE=./data/secure-logs.enc
AI_SHIELD_MAX_IMAGE_BODY_BYTES=8000000
AI_SHIELD_RATE_LIMIT_ANALYZE_PER_MIN=60
AI_SHIELD_RATE_LIMIT_ADMIN_PER_MIN=20
AI_SHIELD_RATE_LIMIT_ADMIN_AUTH_PER_MIN=10